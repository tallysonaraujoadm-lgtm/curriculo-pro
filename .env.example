# URL pública, sem barra no final
BETTER_AUTH_URL=http://localhost:3000

# Gere com: openssl rand -base64 32
BETTER_AUTH_SECRET=troque-por-um-segredo-com-pelo-menos-32-caracteres

# Use a conexão direta ou Session Pooler do Supabase.
# O código ativa SSL; não é necessário adicionar sslmode à URI.
DATABASE_URL=postgresql://postgres.PROJECT_REF:SENHA@aws-0-REGIAO.pooler.supabase.com:5432/postgres

# Resend
RESEND_API_KEY=re_xxxxxxxxx
EMAIL_FROM=Curriculo Pro <contato@seudominio.com>

# OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
